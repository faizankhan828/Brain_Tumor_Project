# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*

# ── Python / Backend ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ── Database (runtime data, not source) ───────────────────────────────────────
*.db
*.sqlite3

# ── Model weights — tracked via Git LFS (.gitattributes) ─────────────────────
# models/brain_tumor_model.h5  → tracked by LFS (see .gitattributes)
models/hf_cache/
models/*.backup.h5

# ── ML training outputs ───────────────────────────────────────────────────────
logs/
app/utils/plots/training_curves.png
app/utils/plots/confusion_matrix.png
app/utils/plots/per_class_metrics.png

# ── Runtime static files (generated at runtime, stored in Docker volume) ──────
static/uploads/
static/heatmaps/

# ── Dataset (too large for git) ───────────────────────────────────────────────
dataset/

# ── Environment / secrets — NEVER commit ──────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

