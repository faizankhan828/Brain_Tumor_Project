# .dockerignore — excluded from Docker build context
# Keeps images small and build fast.

# Node / Frontend build artefacts
node_modules/
dist/

# Python virtual environment and caches
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
htmlcov/

# Dataset (large, not needed at runtime)
dataset/

# Git history
.git/
.gitignore

# Local environment
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.suo
*.sw?
.DS_Store

# Training scripts (not needed at runtime)
retrain_all_classes.py
fix_model.py
diagnose_and_retrain.py
bottleneck_train.py
fast_tune.py
download_pretrained_model.py
app/train.py
app/evaluate.py

# Test files
tests/

# Temporary database (will be in named volume)
*.db
*.sqlite3

# Logs
logs/
*.log

# Static uploads (will be in named volume)
static/uploads/
static/heatmaps/

# Large model backup (keep only the main one)
models/brain_tumor_model.backup.h5
models/hf_cache/
