# ── Backend ───────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Secret key for JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Token expiry in minutes (default: 1440 = 24 h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite (default) — change to PostgreSQL URL for production:
# DATABASE_URL=postgresql://user:password@host:5432/brain_tumor_db
DATABASE_URL=sqlite:///./brain_tumor.db

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the deployed backend (no trailing slash)
# For local dev: http://localhost:8000
# For production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:8000
